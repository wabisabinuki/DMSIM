    "test.dm26-rp1.DMR.DM1/DM1": {
      "kind": "creature",
      "name_ja": "ボルメテウス・リバース・ドラゴン",
      "cost": 5,
      "civilizations": [
        "water"
      ],
      "power": 7000,
      "hyper_power": 12000,
      "race_ja": [
        "エクスドリーマー",
        "アーマード・ドラゴン",
        "超化獣"
      ],
      "special_types": [
        "hyper_mode",
        "dream"
      ],
      "abilities": {
        "keyword": [
          "blocker",
          "double_breaker",
          "unblockable and untouchable",
          "z_rush",
          {
            "ability_id": "triple_breaker",
            "active_if": {
              "type": "source_has_state",
              "state": "hyper_mode"
            }
          }
        ],
        "triggered": [
          {
            "ability_id": "bolmeteus_reverse_dragon_enter_lock",
            "label": "Opponent creatures cannot attack or block",
            "trigger": {
              "type": "enter_battle",
              "card": {
                "ref": "source"
              }
            },
            "effects": [
              {
                "effect_id": "temporary_combat_restriction",
                "scope": "opponent_creatures",
                "restrictions": [
                  "attack",
                  "block"
                ],
                "duration": {
                  "type": "until_start_of_controller_turn"
                }
              }
            ]
          }
        ],
        "replacement": [
          {
            "ability_id": "shield_break_bottom_deck_replacement",
            "type": "shield_break",
            "attempt": {
              "event": "shield_break_attempt",
              "breaker": {
                "ref": "source"
              }
            },
            "active_if": {
              "type": "source_has_state",
              "state": "hyper_mode"
            },
            "replace_with": {
              "cancel_event": true,
              "actions": [
                {
                  "type": "move_event_card",
                  "card": {
                    "ref": "event.shield_card"
                  },
                  "from_zone": "shield",
                  "to_zone": "deck",
                  "reason": "shield_break_replacement",
                  "apply_replacements": false
                }
              ]
            },
            "after_replacement_batch": {
              "effects": [
                {
                  "type": "draw",
                  "player": "each_player",
                  "amount": {
                    "ref": "replacement_count"
                  }
                }
              ]
            }
          }
        ]
      }
    },
